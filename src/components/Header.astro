---
import { SITE_TITLE, NAV_LINKS } from "../consts";
import SearchModal from "./SearchModal.astro";

// 取当前路径，用来高亮当前导航项
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header
  class="sticky top-0 z-50 bg-white/70 backdrop-blur-xl backdrop-saturate-150 transition-colors dark:bg-zinc-950/70"
>
  <nav
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6"
  >
    <a
      href="/"
      class="group flex items-center gap-2.5 text-lg font-semibold tracking-tight text-zinc-900 transition-opacity hover:opacity-80 dark:text-zinc-100"
    >
      <span
        class="grid h-7 w-7 place-items-center rounded-md bg-zinc-900 text-white dark:bg-white dark:text-zinc-900"
      >
        <svg
          viewBox="0 0 24 24"
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M3 12c2-4 4-4 6 0s4 4 6 0 4-4 6 0" />
        </svg>
      </span>
      <span>
        {SITE_TITLE}
      </span>
    </a>

    <div class="flex items-center gap-0.5 sm:gap-1">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              "group relative px-3 py-2 text-sm font-medium transition-colors",
              isActive(link.href)
                ? "text-zinc-900 dark:text-zinc-100"
                : "text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100",
            ]}
          >
            {link.label}
            {isActive(link.href) ? (
              <span class="absolute inset-x-3 -bottom-1.5 h-[2px] rounded-full bg-zinc-900 dark:bg-zinc-100" />
            ) : (
              <span class="absolute inset-x-3 -bottom-1.5 h-[2px] scale-x-0 rounded-full bg-zinc-900 opacity-0 transition-all duration-300 group-hover:scale-x-100 group-hover:opacity-100 dark:bg-zinc-100" />
            )}
          </a>
        ))
      }

      <SearchModal />
    </div>
  </nav>
</header>
