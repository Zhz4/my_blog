---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	image?: ImageMetadata;
	alt: string;
	/** 没有封面图时，用它生成确定性的渐变占位（传 slug 或标题） */
	seed: string;
	class?: string;
	sizes?: string;
	widths?: number[];
	loading?: 'eager' | 'lazy';
}

const {
	image,
	alt,
	seed,
	class: className = '',
	sizes = '(min-width: 768px) 720px, 100vw',
	widths = [400, 800, 1200],
	loading = 'lazy',
} = Astro.props;

// 由 seed 推出一个稳定的色相，保证同一篇文章每次渲染的占位渐变一致
function hueFromSeed(s: string): number {
	let h = 0;
	for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) % 360;
	return h;
}
const h = hueFromSeed(seed);
const fallbackStyle = `background-image:linear-gradient(135deg, hsl(${h} 70% 55%), hsl(${(h + 45) % 360} 72% 45%))`;
---

{
	image ? (
		<Image src={image} alt={alt} widths={widths} sizes={sizes} loading={loading} class={className} />
	) : (
		<div class={className} style={fallbackStyle} role="img" aria-label={alt} />
	)
}
