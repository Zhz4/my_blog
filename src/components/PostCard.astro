---
import FormattedDate from './FormattedDate.astro';

interface Props {
	slug: string;
	title: string;
	description: string;
	pubDate: Date;
	tags?: string[];
}

const { slug, title, description, pubDate, tags = [] } = Astro.props;
---

<article class="group relative py-6">
	<div class="mb-2 flex flex-wrap items-center gap-x-2.5 gap-y-1 text-xs text-gray-400 dark:text-gray-500">
		<FormattedDate date={pubDate} />
		{
			tags.length > 0 && (
				<>
					<span aria-hidden="true" class="text-gray-300 dark:text-gray-600">·</span>
					{tags.map((tag) => (
						<a
							href={`/tags/${tag}/`}
							class="relative z-10 transition-colors hover:text-purple-600 dark:hover:text-purple-400"
						>
							#{tag}
						</a>
					))}
				</>
			)
		}
	</div>

	<h2 class="text-lg font-medium text-gray-900 dark:text-gray-100">
		<!-- after 伪元素把整行变成指向文章的可点击区域 -->
		<a
			href={`/blog/${slug}/`}
			class="transition-colors after:absolute after:inset-0 group-hover:text-purple-600 dark:group-hover:text-purple-400"
		>
			{title}
		</a>
	</h2>

	<p class="mt-1.5 line-clamp-1 text-sm text-gray-500 dark:text-gray-400">{description}</p>
</article>
