---
import FormattedDate from './FormattedDate.astro';

interface Props {
	slug: string;
	title: string;
	description: string;
	pubDate: Date;
	tags?: string[];
}

const { slug, title, description, pubDate, tags = [] } = Astro.props;
---

<article class="group relative rounded-2xl p-6 -mx-6 transition-all duration-300 hover:bg-zinc-50 dark:hover:bg-zinc-900/50">
	<div class="mb-2 flex flex-wrap items-center gap-x-2.5 gap-y-1 text-xs text-zinc-400 dark:text-zinc-600">
		<FormattedDate date={pubDate} />
		{
			tags.length > 0 && (
				<>
					<span aria-hidden="true" class="text-zinc-300 dark:text-zinc-700">·</span>
					{tags.map((tag) => (
						<a
							href={`/tags/${tag}/`}
							class="relative z-10 transition-colors hover:text-zinc-700 dark:hover:text-zinc-300"
						>
							#{tag}
						</a>
					))}
				</>
			)
		}
	</div>

	<h2 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
		<!-- after 伪元素把整行变成指向文章的可点击区域 -->
		<a
			href={`/blog/${slug}/`}
			class="transition-colors after:absolute after:inset-0"
		>
			{title}
		</a>
	</h2>

	<p class="mt-2 line-clamp-2 text-sm leading-relaxed text-zinc-500 dark:text-zinc-500">{description}</p>
</article>
