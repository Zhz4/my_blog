---
import FormattedDate from './FormattedDate.astro';

interface Props {
	slug: string;
	title: string;
	description: string;
	pubDate: Date;
	tags?: string[];
}

const { slug, title, description, pubDate, tags = [] } = Astro.props;
---

<article class="group relative rounded-2xl p-6 -mx-6 transition-all duration-300 hover:bg-zinc-50 dark:hover:bg-zinc-900/50">
	<div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-zinc-400 dark:text-zinc-500">
		<FormattedDate date={pubDate} />
		{
			tags.length > 0 && (
				<>
					<span aria-hidden="true" class="text-gray-300 dark:text-gray-600">·</span>
					{tags.map((tag) => (
						<a
							href={`/tags/${tag}/`}
							class="relative z-10 transition-colors hover:text-zinc-900 dark:hover:text-zinc-100"
						>
							#{tag}
						</a>
					))}
				</>
			)
		}
	</div>

	<h2 class="text-xl font-medium text-zinc-900 dark:text-zinc-100">
		<!-- after 伪元素把整行变成指向文章的可点击区域 -->
		<a
			href={`/blog/${slug}/`}
			class="transition-colors after:absolute after:inset-0"
		>
			{title}
		</a>
	</h2>

	<p class="mt-2.5 line-clamp-2 text-base leading-relaxed text-zinc-500 dark:text-zinc-400">{description}</p>
</article>
