---
import type { MarkdownHeading } from 'astro';

interface Props {
	headings: MarkdownHeading[];
}

const { headings } = Astro.props;
// 只取 h2 / h3 进目录
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{
	toc.length > 0 && (
		<nav class="toc text-sm" aria-label="文章目录">
			<p class="mb-3 font-semibold tracking-wide text-gray-900 uppercase dark:text-gray-100">
				目录
			</p>
			<ul class="space-y-2 border-l border-gray-200 dark:border-gray-800">
				{toc.map((h) => (
					<li class={h.depth === 3 ? 'pl-6' : 'pl-3'}>
						<a
							href={`#${h.slug}`}
							data-toc-link={h.slug}
							class="-ml-px block border-l-2 border-transparent py-0.5 text-gray-500 transition-colors hover:text-purple-600 dark:text-gray-400 dark:hover:text-purple-400"
						>
							{h.text}
						</a>
					</li>
				))}
			</ul>
		</nav>

		<script>
			const links = Array.from(
				document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]')
			);
			const byId = new Map(links.map((l) => [l.dataset.tocLink, l]));
			const activeCls = ['!border-purple-500', 'text-purple-600', 'dark:text-purple-400', 'font-medium'];

			function setActive(id: string | null) {
				links.forEach((l) => l.classList.remove(...activeCls));
				if (id && byId.has(id)) byId.get(id)!.classList.add(...activeCls);
			}

			const headingEls = links
				.map((l) => document.getElementById(l.dataset.tocLink!))
				.filter((el): el is HTMLElement => el !== null);

			const visible = new Set<string>();
			const io = new IntersectionObserver(
				(entries) => {
					for (const e of entries) {
						if (e.isIntersecting) visible.add(e.target.id);
						else visible.delete(e.target.id);
					}
					// 高亮当前视口内最靠上的标题
					const firstVisible = headingEls.find((h) => visible.has(h.id));
					if (firstVisible) setActive(firstVisible.id);
				},
				{ rootMargin: '-80px 0px -65% 0px', threshold: [0, 1] }
			);

			headingEls.forEach((h) => io.observe(h));
			if (headingEls[0]) setActive(headingEls[0].id);
		</script>
	)
}
