---
// 所有页面共用的 <head> 内容：meta、SEO、RSS、防暗色闪烁脚本
import '@fontsource-variable/outfit';
import '@fontsource-variable/playfair-display';
import '@fontsource/noto-serif-sc/400.css';
import '@fontsource/noto-serif-sc/500.css';
import '@fontsource/noto-serif-sc/700.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, image = '/favicon.svg' } = Astro.props;
const fullTitle = title === SITE_TITLE ? title : `${title} · ${SITE_TITLE}`;
---

<!-- 全局 meta -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<!-- 声明本页支持明暗两套配色：脚本执行前（导航提交那一瞬）浏览器据此按系统
     明暗铺底色，避免暗色下刷新/切页时先闪一帧白底 -->
<meta name="color-scheme" content="dark light" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonicalURL} />

<!-- 主要 SEO 标签 -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />

<!-- Open Graph / 社交分享 -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<!-- 在首帧渲染前确定明暗主题，避免暗色模式闪烁；并标记 JS 已启用 -->
<script is:inline>
	(() => {
		function getTheme() {
			const stored = localStorage.getItem('theme');
			if (stored === 'light' || stored === 'dark') return stored;
			return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
		}

		function applyTheme(root) {
			const isDark = getTheme() === 'dark';
			root.classList.add('js');
			root.classList.toggle('dark', isDark);
			// 直接写到 <html> 行内样式：不依赖外部 CSS 加载时序，首帧即生效，
			// 杜绝整页刷新/客户端换页时（CSS 未就绪那一帧）的白底闪烁
			root.style.colorScheme = isDark ? 'dark' : 'light';
			root.style.backgroundColor = isDark ? '#09090b' : '#ffffff';
		}

		applyTheme(document.documentElement);
		window.__applyBlogTheme = applyTheme;

		if (!window.__blogThemeSwapReady) {
			window.__blogThemeSwapReady = true;
			document.addEventListener('astro:before-swap', (event) => {
				applyTheme(event.newDocument.documentElement);
			});
			document.addEventListener('astro:after-swap', () => {
				applyTheme(document.documentElement);
			});
		}
	})();
</script>

<!-- 浏览量统计（Vercount，不蒜子的稳定替代，标签 id 完全兼容）。
     站点用了 ClientRouter，普通脚本只在首次整页加载执行一次，换页后不会重新计数；
     这里改为每次 astro:page-load（含首次加载）都重新注入脚本，让它对当前页重新计数。-->
<script is:inline>
	(() => {
		function loadVercount() {
			// 仅在带浏览量占位符的文章页注入，其它页面跳过
			if (!document.getElementById('vercount_value_page_pv')) return;
			document.getElementById('vercount-script')?.remove();
			const s = document.createElement('script');
			s.id = 'vercount-script';
			s.src = 'https://events.vercount.one/js';
			document.body.appendChild(s);
		}

		if (!window.__vercountReady) {
			window.__vercountReady = true;
			document.addEventListener('astro:page-load', loadVercount);
		}
	})();
</script>
<ClientRouter />
