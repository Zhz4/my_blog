---
import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

interface Props {
	posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

{
	posts.length === 0 ? (
		<p class="border-y border-dashed border-gray-200 py-12 text-center text-sm text-gray-500 dark:border-gray-800 dark:text-gray-400">
			还没有文章。去 <code class="text-sm">src/content/blog</code> 写第一篇吧！
		</p>
	) : (
		<div class="flex flex-col gap-6 sm:gap-8 mt-4">
			{posts.map((post) => (
				<PostCard
					slug={post.id}
					title={post.data.title}
					description={post.data.description}
					pubDate={post.data.pubDate}
					tags={post.data.tags}
				/>
			))}
		</div>
	)
}
