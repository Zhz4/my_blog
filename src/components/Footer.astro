---
import { SITE_TITLE } from '../consts';
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-gray-200 dark:border-gray-800">
	<div
		class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-3 px-4 py-8 text-sm text-gray-500 sm:flex-row sm:px-6 dark:text-gray-400"
	>
		<p>© {year} {SITE_TITLE}. 保留所有权利。</p>
		<div class="flex items-center gap-4">
			<a href="/rss.xml" class="transition-colors hover:text-purple-600 dark:hover:text-purple-400">RSS</a>
			<a
				href="https://astro.build"
				target="_blank"
				rel="noopener noreferrer"
				class="transition-colors hover:text-purple-600 dark:hover:text-purple-400"
			>
				由 Astro 构建
			</a>
		</div>
	</div>
</footer>
