---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} fullHeight>
	<!-- Hero -->
	<section class="flex flex-1 flex-col justify-center py-12">
		<div class="reveal">
			<p
				class="inline-flex items-center gap-2.5 rounded-full border border-zinc-200/60 bg-zinc-50/50 px-3 py-1 text-xs font-medium text-zinc-500 dark:border-zinc-800/60 dark:bg-zinc-900/50 dark:text-zinc-400"
			>
				<span class="relative flex h-2 w-2">
					<span
						class="absolute inline-flex h-full w-full animate-ping rounded-full bg-zinc-400 opacity-75"
					></span>
					<span
						class="relative inline-flex h-2 w-2 rounded-full bg-zinc-500 dark:bg-zinc-400"
					></span>
				</span>
				前端 / AI
			</p>

			<h1
				class="mt-6 font-serif text-6xl font-bold tracking-tight text-zinc-950 sm:text-7xl lg:text-[5.5rem] dark:text-zinc-50 leading-tight"
			>
				<span class="block text-zinc-400 dark:text-zinc-600">Stay hungry,</span>
				<span class="block">Stay foolish.</span>
			</h1>

			<p
				class="mt-6 max-w-2xl font-serif text-lg leading-relaxed tracking-wide text-zinc-500 sm:text-xl dark:text-zinc-400"
			>
				前端开发者，最近在折腾 AI。这里记录我写 React、Vue 和 AI Agent
				时的笔记与踩过的坑。
			</p>

			<div class="mt-10 flex flex-wrap items-center gap-4">
				<a
					href="/blog"
					class="group flex items-center justify-center gap-2 rounded-full bg-zinc-950 px-6 py-3 text-sm font-semibold text-white transition-all hover:scale-105 hover:bg-zinc-800 active:scale-95 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200"
				>
					阅读文章
					<svg
						class="h-4 w-4 transition-transform group-hover:translate-x-1"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						stroke-width="2"
						><path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path></svg
					>
				</a>
				<a
					href="/about"
					class="group flex items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-medium text-zinc-600 transition-colors hover:text-zinc-950 dark:text-zinc-400 dark:hover:text-zinc-50"
				>
					了解我
					<span
						class="relative flex h-px w-3 bg-zinc-400 transition-all group-hover:w-5 dark:bg-zinc-600"
					></span>
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
