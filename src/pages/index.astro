---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// 取最新的 3 篇文章（排除草稿）
const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<!-- Hero -->
	<section class="py-8 sm:py-12">
		<p class="flex items-center gap-2 text-sm text-gray-400 dark:text-gray-500">
			<span class="inline-block h-1.5 w-1.5 rounded-full bg-purple-500"></span>
			用 Astro + Tailwind 构建
		</p>

		<h1 class="mt-5 text-4xl font-semibold tracking-tight sm:text-5xl">
			<span class="text-gray-400 dark:text-gray-500">欢迎来到</span>
			<span class="text-gray-900 dark:text-gray-100">我的博客</span>
		</h1>

		<p class="mt-5 max-w-xl text-lg leading-relaxed text-gray-500 dark:text-gray-400">
			{SITE_DESCRIPTION}
		</p>

		<div class="mt-8 flex items-center gap-6">
			<a
				href="/blog"
				class="rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-gray-700 dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200"
			>
				浏览全部文章
			</a>
			<a
				href="/about"
				class="text-sm font-medium text-gray-500 transition-colors hover:text-purple-600 dark:text-gray-400 dark:hover:text-purple-400"
			>
				关于我 →
			</a>
		</div>
	</section>

	<!-- 最新文章 -->
	<section class="mt-10 sm:mt-14">
		<div class="mb-1 flex items-baseline justify-between">
			<h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">最新文章</h2>
			<a
				href="/blog"
				class="text-sm text-gray-400 transition-colors hover:text-purple-600 dark:text-gray-500 dark:hover:text-purple-400"
			>
				全部 →
			</a>
		</div>

		<PostList posts={posts} />
	</section>
</BaseLayout>
