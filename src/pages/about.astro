---
import BaseLayout from '../layouts/BaseLayout.astro';

const socials = [
	{ label: 'GitHub', href: 'https://github.com/your-name' },
	{ label: 'Email', href: 'mailto:you@example.com' },
	{ label: 'RSS', href: '/rss.xml' },
];
---

<BaseLayout title="关于" description="关于这个博客和我">
	<!-- 头部名片 -->
	<header class="mb-10 flex flex-col items-center gap-4 text-center sm:flex-row sm:text-left">
		<div
			class="grid h-20 w-20 shrink-0 place-items-center rounded-2xl bg-linear-to-br from-purple-600 to-fuchsia-500 text-3xl font-black text-white shadow-md"
		>
			博
		</div>
		<div>
			<h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-gray-100">关于</h1>
			<p class="mt-1 text-gray-600 dark:text-gray-300">你好 👋 这里是我的个人博客。</p>
			<div class="mt-3 flex flex-wrap justify-center gap-2 sm:justify-start">
				{
					socials.map((s) => (
						<a
							href={s.href}
							target={s.href.startsWith('http') ? '_blank' : undefined}
							rel={s.href.startsWith('http') ? 'noopener noreferrer' : undefined}
							class="rounded-lg border border-gray-200 px-3 py-1.5 text-sm font-medium text-gray-700 transition-colors hover:border-purple-300 hover:text-purple-600 dark:border-gray-800 dark:text-gray-200 dark:hover:border-purple-700 dark:hover:text-purple-400"
						>
							{s.label}
						</a>
					))
				}
			</div>
		</div>
	</header>

	<article
		class="prose prose-purple max-w-none dark:prose-invert prose-a:text-purple-600 dark:prose-a:text-purple-400"
	>
		<p>
			这是用 <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
			和 <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer">Tailwind CSS</a> 搭建的个人博客，
			用来记录我的技术笔记、阅读心得和日常思考。
		</p>

		<h2>技术栈</h2>
		<ul>
			<li><strong>Astro</strong> —— 内容优先的静态站点框架，默认零 JavaScript。</li>
			<li><strong>Tailwind CSS v4</strong> —— 原子化 CSS，配合官方 Typography 插件渲染文章。</li>
			<li><strong>Content Collections</strong> —— 用类型安全的方式管理 Markdown / MDX 文章。</li>
			<li><strong>Giscus</strong> —— 基于 GitHub Discussions 的评论系统。</li>
			<li><strong>RSS + Sitemap</strong> —— 方便订阅与搜索引擎收录。</li>
		</ul>

		<h2>联系我</h2>
		<p>把上面的 GitHub / Email 链接换成你自己的即可。也欢迎在文章下方留言交流。</p>
	</article>
</BaseLayout>
