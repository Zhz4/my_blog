---
import BaseLayout from "../layouts/BaseLayout.astro";

const socials = [
	{ label: "GitHub", href: "https://github.com/your-name" },
	{ label: "Email", href: "mailto:you@example.com" },
	{ label: "RSS", href: "/rss.xml" },
];
---

<BaseLayout title="关于" description="关于这个博客和我">
	<!-- 头部名片 -->
	<header
		class="mb-10 flex flex-col items-center gap-4 text-center sm:flex-row sm:text-left"
	>
		<div
			class="grid h-20 w-20 shrink-0 place-items-center rounded-2xl bg-zinc-900 text-3xl font-bold text-white dark:bg-white dark:text-zinc-900"
		>
			S
		</div>
		<div>
			<h1
				class="text-3xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100"
			>
				Smooth
			</h1>
			<p class="mt-1 text-zinc-600 dark:text-zinc-400">
				前端开发者 / AI 领域探索者 👋
			</p>
			<div
				class="mt-3 flex flex-wrap justify-center gap-2 sm:justify-start"
			>
				{
					socials.map((s) => (
						<a
							href={s.href}
							target={
								s.href.startsWith("http") ? "_blank" : undefined
							}
							rel={
								s.href.startsWith("http")
									? "noopener noreferrer"
									: undefined
							}
							class="rounded-lg border border-zinc-200 px-3 py-1.5 text-sm font-medium text-zinc-600 transition-colors hover:border-zinc-300 hover:text-zinc-900 dark:border-zinc-800 dark:text-zinc-300 dark:hover:border-zinc-700 dark:hover:text-zinc-100"
						>
							{s.label}
						</a>
					))
				}
			</div>
		</div>
	</header>

	<article
		class="prose prose-zinc max-w-none dark:prose-invert prose-a:text-zinc-900 dark:prose-a:text-zinc-100"
	>
		<p>
			你好，我是 <strong>Smooth</strong>。
		</p>
		<p>
			我是一名专注于构建卓越用户体验的前端开发者，目前正在深入学习 AI
			相关的知识，探索如何将大模型技术融入到日常开发与设计中。
			我相信优秀的产品不仅需要坚如磐石的代码架构，更需要让人一眼惊艳、一用倾心的交互设计。
		</p>
		<p>在这个由代码构建的数字花园里，我会分享：</p>
		<ul>
			<li>
				<strong>前端技术</strong>：关于 React / Vue、Astro、Tailwind
				等现代 Web 框架的实践心得。
			</li>
			<li>
				<strong>AI 探索</strong>：学习大模型、Prompt 工程以及 AI
				工具如何赋能工作流的笔记。
			</li>
			<li>
				<strong>生活随想</strong
				>：阅读笔记、效率工具分享以及一些天马行空的灵感瞬间。
			</li>
		</ul>

		<h2>当前状态</h2>
		<p>
			目前我正专注于打磨自己的前端技术栈，并积极投身于 AI 知识的浪潮中。
			如果你对我所做的事情感兴趣，或者仅仅是想交个朋友，随时欢迎通过上方的联系方式找到我。
		</p>
	</article>
</BaseLayout>
