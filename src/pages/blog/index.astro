---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import Pagination from '../../components/Pagination.astro';
import { POSTS_PER_PAGE } from '../../consts';

// 第 1 页
const all = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const totalPages = Math.max(1, Math.ceil(all.length / POSTS_PER_PAGE));
const posts = all.slice(0, POSTS_PER_PAGE);
---

<BaseLayout title="博客" description="全部文章列表">
	<header class="mb-8">
		<h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-gray-100">博客</h1>
		<p class="mt-2 text-gray-600 dark:text-gray-300">共 {all.length} 篇文章。</p>
	</header>

	<PostList posts={posts} />
	<Pagination currentPage={1} totalPages={totalPages} />
</BaseLayout>
